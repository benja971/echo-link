# ─── echo-link v2 — production env template ─────────────────────────────────
# Copy this to .env.production and fill in the CHANGE_ME values.
# zod (apps/web/src/lib/server/env.ts) refuses to start with anything missing
# or with placeholder values for the security-critical secrets.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Database (Postgres) ─────────────────────────────────────────────────────
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=echolink
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_NAME=echolink
DATABASE_SSL=0
DATABASE_LOGGING=0

# ─── S3 / MinIO ──────────────────────────────────────────────────────────────
S3_ENDPOINT=minio
S3_PORT=9000
S3_USE_SSL=false
S3_REGION=us-east-1
S3_BUCKET_NAME=echo-link
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY

# ─── Public URLs ─────────────────────────────────────────────────────────────
PUBLIC_BASE_URL=https://echo-link.your-domain.tld
CDN_PUBLIC_BASE_URL=https://cdn.your-domain.tld

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Magic-link auth + future notifications. EMAIL_FROM must be a verified
# Resend sender (or onboarding@resend.dev for early dev).
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
EMAIL_FROM=echo-link <noreply@your-domain.tld>

# ─── Auth secrets (generate fresh) ───────────────────────────────────────────
# SESSION_SECRET must be ≥ 32 chars   →  openssl rand -hex 32
# ANONYMOUS_IP_SALT must be ≥ 16 chars →  openssl rand -hex 16
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
ANONYMOUS_IP_SALT=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_16
MAGIC_LINK_EXPIRATION_MINUTES=15

# ─── Per-account quotas ──────────────────────────────────────────────────────
FILE_EXPIRATION_DAYS=10
MAX_SIZE_MB=100
MAX_PER_USER=25
MAX_SIZE_MB_PER_USER=500

# ─── Anonymous demo dropzone ─────────────────────────────────────────────────
# Anti-abuse for the public landing dropzone. ANON_ENABLED=false kills the
# feature in one config reload.
ANON_ENABLED=true
ANON_MAX_SIZE_MB=50
ANON_MAX_PER_IP_PER_DAY=3
ANON_EXPIRATION_HOURS=24

# ─── Discord bot ─────────────────────────────────────────────────────────────
# DISCORD_BOT_TOKEN + DISCORD_CLIENT_ID come from the Discord Developer
# Portal. Leave DISCORD_GUILD_ID empty in prod for global slash command
# registration (set it for instant registration in dev).
DISCORD_BOT_TOKEN=CHANGE_ME_DISCORD_BOT_TOKEN
DISCORD_CLIENT_ID=CHANGE_ME_DISCORD_CLIENT_ID
DISCORD_GUILD_ID=

# Bot↔web shared secret. Generate fresh: openssl rand -hex 32
ECHOLINK_BOT_TOKEN=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
# URL the bot uses to call back into the web API (internal docker DNS).
ECHOLINK_BASE_URL=http://web:3000
